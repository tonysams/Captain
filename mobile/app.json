{
  "expo": {
    "name": "Instructor Buddy",
    "slug": "instructor-buddy",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "instructorbuddy",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0f1e"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.instructorbuddy.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Instructor Buddy needs camera access to record skiing sessions.",
        "NSMicrophoneUsageDescription": "Instructor Buddy records audio with video for coaching context.",
        "NSPhotoLibraryUsageDescription": "Instructor Buddy can analyze videos from your photo library."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0f1e"
      },
      "package": "com.instructorbuddy.app",
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Instructor Buddy needs camera access to record skiing sessions."
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "Instructor Buddy records audio with video for coaching context."
        }
      ],
      "react-native-video"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
